# ===== KOMPRESJA GZIP =====
<IfModule mod_deflate.c>
  # Kompresja tekstowa
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/webp
  
  # Obsługa przeglądarek
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  
  # Obsługa proxy
  Header append Vary User-Agent
</IfModule>

# ===== BROWSER CACHING =====
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Obrazy - 1 rok (immutable hash)
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  
  # CSS i JavaScript - 1 rok (hash w nazwie pliku)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  
  # Fonty - 1 rok
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  
  # HTML - bez cache (zawsze świeże)
  ExpiresByType text/html "access plus 0 seconds"
  
  # JSON, XML - 1 godzina
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 hour"
</IfModule>

# ===== CACHE CONTROL HEADERS =====
<IfModule mod_headers.c>
  # Immutable cache dla hashowanych assetów
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|css|js|woff|woff2|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # No cache dla HTML
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
  
  # Security Headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # HSTS — wymuś HTTPS na poziomie przeglądarki (bez includeSubDomains/preload = bezpieczny start, łatwy do wycofania)
  Header always set Strict-Transport-Security "max-age=31536000"

  # CORS dla publicznych kontraktów integracyjnych (.json/.txt/.xml) — pozwala fermly.pl
  # fetchować dane serowarni po stronie klienta. Tylko pliki danych, dane i tak publiczne.
  <FilesMatch "\.(json|txt|xml)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# ===== SPA ROUTING (React Router) =====
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- Kanonikalizacja hosta i protokołu (SEO: usuwa duplikaty www/http) ---
  # 1) www -> bez www (i od razu wymuszenie https) — jeden przeskok
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # 2) http -> https (loop-safe: uwzględnia proxy home.pl przez X-Forwarded-Proto)
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # --- Korekty starych/błędnych ścieżek (SEO: eliminuje pozorne 404) ---
  # /przepis/<id> (liczba pojedyncza) -> /przepisy/<id> (https, jeden przeskok)
  RewriteRule ^przepis/(.+)$ https://mojaserowarnia.pl/przepisy/$1 [R=301,L]
  # literówka w starej trasie kalkulatora wartości odżywczych (https, jeden przeskok)
  RewriteRule ^porownawie-wartosci-odzywczych/?$ https://mojaserowarnia.pl/porownanie-wartosci-odzywczych [R=301,L]
  # stary mirror etykiety -> opisowy slug GEO (mirror przeniesiony, jeden przeskok)
  RewriteRule ^etykieta-rhd\.html$ https://mojaserowarnia.pl/etykieta-do-sprzedazy-rhd.html [R=301,L]
  # /kalkulator (bez sufiksu) nie jest trasą -> hub narzędzi (usuwa pozorne 404)
  RewriteRule ^kalkulator/?$ https://mojaserowarnia.pl/narzedzia [R=301,L]
  # /wege -> /wege/ jawnie na https (Apache DirectorySlash robił przeskok na http = błąd przekierowania)
  RewriteRule ^wege$ https://mojaserowarnia.pl/wege/ [R=301,L]

  # --- Prerender dla botów społecznościowych (per-strona OG: tytuł, opis, obraz) ---
  # FB/Twitter/LinkedIn/WhatsApp itd. NIE renderują JS, więc dla tras React dostawałyby
  # generyczny index.html. Zamiast tego serwujemy im statyczny mirror (jeśli istnieje),
  # który ma własny og:title/description/image. Googlebot NIE jest tu ujęty (indeksuje
  # wersję kanoniczną). Ludzie (zwykłe przeglądarki) dostają normalnie aplikację React.
  # $1 z RewriteRule jest dostępne w poprzedzającym RewriteCond (kolejność mod_rewrite).
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|Slackbot|TelegramBot|Discordbot|Pinterest|redditbot|Applebot|SkypeUriPreview|vkShare|Embedly) [NC]
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([^.]+?)/?$ /$1.html [L]

  # --- Trasy SPA kolidujące z fizycznym katalogiem ---
  # /przepisy ma podstrony statyczne (/przepisy/*.html), ale samo /przepisy to trasa React.
  # Bez tego Apache widzi katalog bez index.html i zwraca 403. Serwujemy aplikację.
  # (Pliki /przepisy/<coś>.html nadal działają — ta reguła łapie tylko samo /przepisy[/].)
  RewriteRule ^przepisy/?$ /index.html [L]
  # /prawo ma podstrony statyczne (/prawo/*.html) — to samo zabezpieczenie co dla /przepisy.
  RewriteRule ^prawo/?$ /index.html [L]

  # Nie przepisuj istniejących plików i katalogów
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Przepisz wszystko inne na index.html
  RewriteRule ^(.*)$ /index.html [L,QSA]
</IfModule>

# ===== MIME TYPES =====
<IfModule mod_mime.c>
  # WebP
  AddType image/webp .webp
  
  # Fonts
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType font/ttf .ttf
  
  # JavaScript
  AddType application/javascript .js
  AddType text/javascript .js
  
  # CSS
  AddType text/css .css

  # Wymuszenie UTF-8 dla plikow tekstowych z polskimi znakami
  # (llms.txt, kultury.summary.txt, sitemap.xml — bez tego ryzyko zlej dekodacji przy nosniff)
  AddCharset utf-8 .txt .xml
</IfModule>

# ===== OPTYMALIZACJA ETags =====
FileETag MTime Size

# ===== WYŁĄCZENIE SERVER SIGNATURE =====
ServerSignature Off
